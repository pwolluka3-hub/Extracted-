NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# Core Authentication
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# Server-Side AI Provider Keys (for /api/ai/chat proxy)
# Recommended for production to avoid exposing keys in browser
# ============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GITHUB_MODELS_API_KEY=
BYTEZ_API_KEY=
POE_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=

# ============================================================================
# Media Generation Providers
# ============================================================================
# Image generation
STABILITY_API_KEY=          # Stability AI (Stable Diffusion)
REPLICATE_API_KEY=          # Replicate (multiple models)
IDEOGRAM_API_KEY=           # Ideogram AI

# Video generation
RUNWAY_API_KEY=             # Runway ML
# REPLICATE_API_KEY= (can be reused for video)

# Audio/Voice
ELEVENLABS_API_KEY=         # ElevenLabs TTS
# OPENAI_API_KEY= (can be reused for TTS)

# ============================================================================
# Puter.js Configuration (optional, for file storage)
# ============================================================================
NEXT_PUBLIC_PUTER_DOMAIN=https://puter.com
NEXT_PUBLIC_PUTER_BASE_PATH=/NexusAI    # Custom base path for file storage

# ============================================================================
# Video Generation
# ============================================================================
NEXT_PUBLIC_LTX_ENDPOINT=fal-ai/ltx-2.3/text-to-video/fast
NEXT_PUBLIC_LTX_OPEN_ENDPOINT=http://localhost:8000/generate

# ============================================================================
# Mobile/Protocol Configuration
# ============================================================================
# Set to 'true' if running from file:// protocol on Android
# Enables memory-fallback storage when localStorage is blocked
NEXT_PUBLIC_FILE_PROTOCOL_MODE=false
